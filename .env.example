# ==============================================================================
# Power BI AI Copilot Configuration
# ==============================================================================
# Copy this file to .env and update with your actual values

# API Configuration
DEBUG=False
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database Configuration
DATABASE_URL=postgresql://copilot_user:copilot_password@localhost:5432/powerbi_copilot
REDIS_URL=redis://localhost:6379/0

# LLM Provider Configuration
# Choose between: openai, groq
LLM_PROVIDER=groq

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Groq Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Embeddings Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# RAG Configuration
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# Memory Configuration
MEMORY_MAX_TURNS=10
SESSION_TIMEOUT=3600

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
ENABLE_TRACING=true
ENABLE_METRICS=true

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ==============================================================================
# Notes:
# 1. For production, ensure all sensitive values are stored in a secret manager
# 2. Use strong SECRET_KEY values
# 3. Set appropriate database credentials
# 4. Obtain API keys from respective LLM providers
# ==============================================================================
